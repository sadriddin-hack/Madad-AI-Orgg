{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role-based access",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["PATIENT", "DOCTOR"] },
        "specialty": { "type": "string", "description": "Only for Doctors" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "fullName", "email", "role"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Medical appointment and consultation record",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "doctorId": { "type": "string" },
        "doctorName": { "type": "string" },
        "symptoms": { "type": "string" },
        "aiSummary": { "type": "string" },
        "status": { "type": "string", "enum": ["WAITING", "IN_PROGRESS", "COMPLETED"] },
        "scheduledTime": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "doctorId", "status"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "User profiles"
    },
    "appointments": {
      "schema": "Appointment",
      "description": "Medical appointments"
    }
  }
}
